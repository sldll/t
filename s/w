#!/bin/sh

# Fetch weather with 2-second timeout
weather=$(curl -Ss --max-time 2 'https://wttr.in/Rijswijk?format=4' 2>/dev/null)

# Default fallback if empty
if [ -z "$weather" ]; then
    echo "🌤 N/A"
    exit 0
fi

# Process output: first 2 lines, trim, flatten, remove trailing spaces
output=$(echo "$weather" | head -2 | cut -c16- | tr '\n' ' ' | sed 's/ *$//')

# Print to i3blocks
echo "$output"
exit 0
