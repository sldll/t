#!/bin/sh
# ~/.config/i3blocks/weather.sh

# Fetch weather, timeout after 2 seconds
weather=$(curl -Ss --max-time 2 'https://wttr.in/Rijswijk?format=4' 2>/dev/null)

# Fallback if empty
if [ -z "$weather" ]; then
    echo "🌤 N/A"
    exit 0
fi

# Take first 2 lines, remove leading/trailing spaces, flatten into one line
output=$(echo "$weather" | head -2 | awk '{$1=$1; print}' | tr '\n' ' ' | sed 's/[[:space:]]*$//')

echo "$output"
exit 0
